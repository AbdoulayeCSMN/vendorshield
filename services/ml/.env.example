# ── VendorShield ML — configuration (prefix VS_ML_) ──────────────────────────

# Read-only SQLAlchemy DSN to the Supabase Postgres (training/scoring source).
# postgresql+psycopg://postgres:<password>@db.<ref>.supabase.co:5432/postgres
VS_ML_DATABASE_URL=

# Optional MLflow tracking server (defaults to a local file store under artifacts/).
# VS_ML_MLFLOW_TRACKING_URI=http://localhost:5000
VS_ML_MLFLOW_EXPERIMENT=vendorshield-operational-risk

# Protect the /predict endpoint (sent by the Next.js app as X-API-Key).
VS_ML_API_KEY=

# Modelling
VS_ML_MIN_SUPPLIER_HISTORY=8
VS_ML_PPM_BREACH_THRESHOLD=5000
VS_ML_CV_FOLDS=5
