# ============================================================================
# VendorShield — variables d'environnement (TEMPLATE)
# ----------------------------------------------------------------------------
# Copiez ce fichier en `.env.local` et renseignez vos valeurs.
# NE COMMITTEZ JAMAIS de vraies clés : `.env.local` / `.env.development` /
# `.env.production` / `.env.test` sont gitignorés. Seul ce `.env.example`
# (placeholders) est versionné.
# Tout ce qui est préfixé NEXT_PUBLIC_ est exposé au navigateur (jamais de secret).
# ============================================================================

# ─── Supabase (REQUIS) ──────────────────────────────────────────────────────
# Dashboard Supabase → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://votre-projet.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=votre-cle-anon-publique
# SECRET — bypass total de la RLS. Uniquement en local / variables de la
# plateforme de déploiement. JAMAIS dans un fichier versionné.
SUPABASE_SERVICE_ROLE_KEY=votre-service-role-key

# ─── Site / application ─────────────────────────────────────────────────────
# URL publique (redirections Checkout/Portal, liens du portail fournisseur)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── IA / LLM (copilote, analyses, explications) ────────────────────────────
# Priorité : MOCK_AI > OPENROUTER_API_KEY > GROQ_API_KEY
# Dev sans clé : réponses simulées réalistes.
MOCK_AI=true
# OpenRouter (recommandé) — openrouter.ai → Keys. Utilisé par le copilote et
# les explications de prédiction.
OPENROUTER_API_KEY=sk-or-...
# (optionnel) override des modèles — modèles gratuits *instruct*, max 3.
# OPENROUTER_MODELS=google/gemma-4-31b-it:free,google/gemma-4-26b-a4b-it:free,meta-llama/llama-3.3-70b-instruct:free
# Repli Groq (optionnel) — console.groq.com
# GROQ_API_KEY=gsk_...

# ─── Service ML Python (optionnel) ──────────────────────────────────────────
# Si défini, l'app interroge le microservice FastAPI (services/ml) pour les
# prédictions ; sinon repli automatique sur le modèle TS embarqué.
# ML_SERVICE_URL=http://localhost:8000
# ML_SERVICE_API_KEY=changez-moi

# ─── Facturation Stripe (optionnel) ─────────────────────────────────────────
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# NEXT_PUBLIC_STRIPE_PRICE_STARTER_MONTHLY=price_...
# NEXT_PUBLIC_STRIPE_PRICE_STARTER_YEARLY=price_...
# NEXT_PUBLIC_STRIPE_PRICE_PRO_MONTHLY=price_...
# NEXT_PUBLIC_STRIPE_PRICE_PRO_YEARLY=price_...

# ─── Email / alertes (optionnel) ────────────────────────────────────────────
# Resend → resend.com. + Database Webhook Supabase sur la table `alerts`.
# RESEND_API_KEY=re_...
# EMAIL_FROM=VendorShield <alertes@votredomaine.io>
# ALERTS_WEBHOOK_SECRET=chaine-aleatoire-longue

# ─── Surveillance automatique (optionnel) ───────────────────────────────────
# Scan planifié des fournisseurs à risque → POST/GET /api/monitoring/scan.
# Protégé par x-monitoring-secret, ou par Vercel Cron (Authorization: Bearer CRON_SECRET).
# MONITORING_SCAN_SECRET=chaine-aleatoire-longue
# CRON_SECRET=defini-par-vercel-cron

# ─── Mode démo public (optionnel) ───────────────────────────────────────────
# Compte démo connecté automatiquement sur /demo (lecture seule).
# DEMO_EMAIL=demo@votredomaine.io
# DEMO_PASSWORD=mot-de-passe-demo
